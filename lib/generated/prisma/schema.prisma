generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ===== UTILISATEURS =====
model User {
  id        String   @id @default(cuid())
  phone     String   @unique
  name      String
  role      Role     @default(CLIENT)
  createdAt DateTime @default(now())

  artisan        Artisan?
  demandesClient Demande[]     @relation("DemandesDuClient")
  avisDonnes     Avis[]
  signalements   Signalement[]
}

enum Role {
  CLIENT
  ARTISAN
  ADMIN
}

// ===== ARTIZENS (profil métier) =====
model Artisan {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  metiers    Metier[]
  commune    String
  verifie    Boolean  @default(false)
  note       Float    @default(0)
  nbAvis     Int      @default(0)
  experience Int      @default(0)
  soldeKobo  Int      @default(0)
  createdAt  DateTime @default(now())

  demandes          Demande[]     @relation("DemandesDeLArtisan")
  avisRecus         Avis[]
  signalementsRecus Signalement[]
}

enum Metier {
  CLIMATISATION
  PLOMBERIE
  ELECTRICITE
  ELECTROMENAGER
  PEINTURE
}

// ===== DEMANDES =====
model Demande {
  id          String        @id @default(cuid())
  metier      Metier
  description String
  commune     String
  adresse     String
  statut      StatutDemande @default(EN_ATTENTE)
  prixDevis   Int?
  createdAt   DateTime      @default(now())

  clientId String
  client   User   @relation("DemandesDuClient", fields: [clientId], references: [id])

  artisanId String?
  artisan   Artisan? @relation("DemandesDeLArtisan", fields: [artisanId], references: [id])

  avis        Avis?
  signalement Signalement?
}

enum StatutDemande {
  EN_ATTENTE
  ACCEPTEE
  EN_COURS
  TERMINEE
  CONFIRMEE
  PAYEE
  ANNULEE
}

// ===== AVIS (notation client -> artisan) =====
model Avis {
  id          String   @id @default(cuid())
  note        Int // de 1 à 5
  commentaire String   @default("")
  createdAt   DateTime @default(now())

  demandeId String  @unique
  demande   Demande @relation(fields: [demandeId], references: [id])

  artisanId String
  artisan   Artisan @relation(fields: [artisanId], references: [id])

  clientId String
  client   User   @relation(fields: [clientId], references: [id])
}

// ===== SIGNALEMENTS (client -> artisan, vu par l'admin) =====
model Signalement {
  id          String            @id @default(cuid())
  motif       MotifSignalement
  description String            @default("")
  statut      StatutSignalement @default(NOUVEAU)
  createdAt   DateTime          @default(now())

  demandeId String?  @unique
  demande   Demande? @relation(fields: [demandeId], references: [id])

  artisanId String
  artisan   Artisan @relation(fields: [artisanId], references: [id])

  clientId String
  client   User   @relation(fields: [clientId], references: [id])
}

enum MotifSignalement {
  TRAVAIL_MAL_FAIT
  PRIX_ABUSIF
  COMPORTEMENT
  ABSENT
  AUTRE
}

enum StatutSignalement {
  NOUVEAU
  TRAITE
}

// ===== CODES DE VÉRIFICATION =====
model CodeVerif {
  id        String   @id @default(cuid())
  phone     String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([phone])
}
